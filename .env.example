# AWS Configuration
AWS_REGION=us-east-1

# DynamoDB Table Names
LOGIN_TABLE=login
MUSIC_TABLE=music
SUBSCRIPTIONS_TABLE=subscriptions

# DynamoDB Index Names
MUSIC_TITLE_INDEX=title-index
MUSIC_YEAR_ALBUM_INDEX=year-album-index

# Flask Backend
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=True

# CORS
CORS_ORIGINS=*

# Optional future frontend/base URLs
FRONTEND_URL=http://localhost:3000

# Optional S3 values for next section
S3_BUCKET_NAME=
S3_IMAGE_PREFIX=artist-images/