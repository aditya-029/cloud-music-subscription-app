# =========================================================
# Python cache and compiled files
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# =========================================================
# Python virtual environments
# =========================================================
.venv/
venv/
env/
ENV/
myenv/

# =========================================================
# Environment variables and secrets
# =========================================================
.env
.env.*
!.env.example

# AWS credentials / local AWS config must never be committed
.aws/
aws_credentials*
credentials
config.local
*.pem
*.key

# =========================================================
# Local temporary files
# =========================================================
tmp/
temp/
.tmp/
*.tmp
*.bak

# Downloaded artist images generated by s3/upload_artist_images.py
tmp_artist_images/

# =========================================================
# Logs
# =========================================================
*.log
logs/

# =========================================================
# macOS / Windows system files
# =========================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================================================
# IDE/editor files
# =========================================================
.vscode/
.idea/
*.swp
*.swo

# =========================================================
# Test and coverage output
# =========================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =========================================================
# Build, package, and deployment artefacts
# =========================================================
*.zip
*.tar
*.tar.gz
*.tgz
dist/
build/
*.egg-info/
.eggs/

# Lambda deployment packages/layers
lambda_package/
lambda_layer/
python/

# =========================================================
# Node/frontend dependencies and build output
# For teammates if they use npm/Vite/React later
# =========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Frontend build folders
frontend/dist/
frontend/build/
frontend/.vite/

# =========================================================
# Local database/output files
# =========================================================
*.sqlite
*.sqlite3
*.db

# =========================================================
# Reports and document temporary files
# =========================================================
~$*.docx
~$*.xlsx
~$*.pptx

# Keep final submitted PDFs only if the group intentionally commits them.
# Otherwise uncomment these:
# *.pdf
# *.docx

# =========================================================
# Terraform / infrastructure tools if used later
# =========================================================
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =========================================================
# Docker local files
# =========================================================
.docker/
docker-compose.override.yml

# =========================================================
# Miscellaneous
# =========================================================
.cache/